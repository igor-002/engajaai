# Public site URL (used for OAuth callbacks, webhook URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Payment provider selection
# values: abacate | stripe
PAYMENT_PROVIDER=abacate

# Abacate Pay — accepts dev (abc_dev_*) or prod (abc_prod_*) keys
ABACATE_API_KEY=
# HMAC secret used to verify X-Webhook-Signature header
ABACATE_WEBHOOK_SECRET=
# Optional extra secret appended as ?webhookSecret=... in the webhook URL
ABACATE_WEBHOOK_URL_SECRET=

# Stripe (not yet wired)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
